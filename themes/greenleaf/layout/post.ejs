<div style="flex: 1; max-width: 960px; margin: 0 auto; padding: var(--space-12) var(--space-8);">
  <div style="display: flex; flex-wrap: wrap; gap: var(--space-6); align-items: flex-start;">

    <!-- LEFT: Article Content (~68%) -->
    <article style="flex: 1; min-width: 0; max-width: 68%; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-8);">

      <!-- Article Header -->
      <header>
        <h1 style="margin: 0; font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: var(--font-weight-bold); line-height: var(--leading-tight); color: var(--color-text-primary); word-break: keep-all; overflow-wrap: break-word;">
          <%= page.title %>
        </h1>

        <!-- Meta Row -->
        <div style="display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-tertiary);">
          <time datetime="<%= page.date.format('YYYY-MM-DD') %>"><%= page.date.format('YYYY-MM-DD') %></time>
          <span style="color: var(--color-border);">|</span>
          <% if (page.categories && page.categories.length) { %>
            <% page.categories.forEach(function(cat, idx) { %>
            <span style="display: inline-flex; align-items: center; white-space: nowrap; padding: 2px 10px; border-radius: var(--radius-sm); background-color: var(--color-primary-lightest); color: var(--color-primary); font-weight: var(--font-weight-medium);">
              <a href="<%= url_for(cat.path) %>" style="text-decoration: none; color: inherit;"><%= cat.name %></a>
            </span>
            <% if (idx < page.categories.length - 1) { %><span style="color: var(--color-border);">|</span><% } %>
            <% }) %>
          <% } %>
          <span style="color: var(--color-border);">|</span>
          <span>约 <%= Math.ceil((strip_html(page.content).length || 0) / 400) %> 分钟</span>
        </div>

        <!-- Divider -->
        <hr style="border: none; border-top: 1px solid var(--color-border); margin-top: var(--space-6); margin-bottom: var(--space-8);" />
      </header>

      <!-- Article Body -->
      <div style="font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--color-text-primary);">
        <%- page.content %>
      </div>

      <!-- Article Footer -->
      <footer style="margin-top: var(--space-12);">
        <hr style="border: none; border-top: 1px solid var(--color-border); margin-bottom: var(--space-6);" />

        <!-- Tags -->
        <% if (page.tags && page.tags.length) { %>
        <div style="display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-8);">
          <span style="font-size: var(--text-sm); color: var(--color-text-tertiary);">标签：</span>
          <% page.tags.forEach(function(tag) { %>
          <a href="<%= url_for(tag.path) %>" style="display: inline-flex; align-items: center; white-space: nowrap; text-decoration: none; padding: 3px 10px; border-radius: var(--radius-full); background-color: var(--color-bg-alt); color: var(--color-text-secondary); font-size: var(--text-sm); border: 1px solid var(--color-border); transition: color var(--transition-fast), border-color var(--transition-fast);" onmouseover="this.style.color='var(--color-primary)';this.style.borderColor='var(--color-primary)'" onmouseout="this.style.color='var(--color-text-secondary)';this.style.borderColor='var(--color-border)'">
            <%= tag.name %>
          </a>
          <% }) %>
        </div>
        <% } %>

        <!-- Prev / Next Navigation -->
        <nav style="display: flex; justify-content: space-between; align-items: center; gap: var(--space-8); margin-bottom: var(--space-8); font-size: var(--text-base); color: var(--color-text-primary); flex-wrap: wrap;">
          <% if (page.prev) { %>
          <a href="<%= url_for(page.prev.path) %>" style="color: inherit; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 45%;"
             onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-text-primary)'">
            上一篇：<%= page.prev.title %>
          </a>
          <% } else { %><span></span><% } %>
          <% if (page.next) { %>
          <a href="<%= url_for(page.next.path) %>" style="color: inherit; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 45%;"
             onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-text-primary)'">
            下一篇：<%= page.next.title %>
          </a>
          <% } %>
        </nav>
      </footer>

    </article>

    <!-- RIGHT: Sidebar (~30%) -->
    <%- partial('_partial/sidebar', { show_sidebar: true }) %>

  </div>
</div>