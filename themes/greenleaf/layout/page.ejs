<div style="max-width: 720px; margin: 0 auto; padding: var(--space-12) var(--space-8);">
  <h1 style="margin: 0 0 var(--space-8); font-family: var(--font-serif); font-size: var(--text-2xl); font-weight: var(--font-weight-bold); color: var(--color-text-primary);">
    <%= page.title %>
  </h1>
  <div style="font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--color-text-primary);">
    <%- page.content %>
  </div>
</div>