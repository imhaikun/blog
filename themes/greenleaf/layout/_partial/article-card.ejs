<div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); margin-bottom: var(--space-6); background-color: var(--color-surface); transition: background-color var(--transition-fast);" onmouseover="this.style.backgroundColor='var(--color-surface-hover)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
  <h2 style="margin: 0 0 var(--space-2); font-family: var(--font-serif); font-size: var(--text-2xl); font-weight: var(--font-weight-bold); color: var(--color-text-primary);">
    <a href="<%= url_for(post.path) %>" style="color: var(--color-text-primary); text-decoration: none; transition: color var(--transition-fast);" onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-text-primary)'">
      <%= post.title %>
    </a>
  </h2>
  <div style="display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-3); font-size: var(--text-sm); color: var(--color-text-tertiary);">
    <time datetime="<%= post.date.format('YYYY-MM-DD') %>"><%= post.date.format('YYYY-MM-DD') %></time>
    <span style="color: var(--color-border);">|</span>
    <% post.categories.forEach(function(cat, idx) { %>
    <% if (idx > 0) { %><span style="color: var(--color-border);">|</span><% } %>
    <span style="display: inline-flex; align-items: center; white-space: nowrap; padding: 2px 10px; border-radius: var(--radius-sm); background-color: var(--color-primary-lightest); color: var(--color-primary); font-weight: var(--font-weight-medium);">
      <a href="<%= url_for(cat.path) %>" style="text-decoration: none; color: inherit;"><%= cat.name %></a>
    </span>
    <% }) %>
  </div>
  <p style="margin: 0 0 var(--space-3); font-size: var(--text-base); color: var(--color-text-secondary); line-height: var(--leading-normal);">
    <%- post.excerpt || strip_html(post.content).substring(0, 150) + '...' %>
  </p>
  <a href="<%= url_for(post.path) %>" style="font-size: var(--text-sm); color: var(--color-primary); font-weight: var(--font-weight-medium); text-decoration: none; display: inline-block; transition: opacity var(--transition-fast);" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
    阅读全文 →
  </a>
</div>